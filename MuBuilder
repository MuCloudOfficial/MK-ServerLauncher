pipeline {
  agent none
  stages {
    stage('MuView') {
      agent {
        docker {
          image 'node:22.16-alpine'
        }

      }
      steps {
        dir(path: '/var/jenkins_home/workspace/Launcher-Remote_jenkins-featured/view') {
          echo '[MuBuild] Building MuView '
          sh 'npm install'
          sh 'npm run build --outDir ../Core/src/main/resources/MuView'
        }

      }
    }

    stage('MuCore') {
      agent {
        docker {
          image 'gradle:8.14-jdk11'
        }

      }
      steps {
        dir(path: '/var/jenkins_home/workspace/Launcher-Remote_jenkins-featured/Core') {
          echo '[MuBuilder] Building MuCore'
          sh 'sh ./gradlew build -x test'
          archiveArtifacts(artifacts: '**/build/distributions/*.*, **/build/libs/Core-all.jar', fingerprint: true)
        }

      }
    }

  }
}