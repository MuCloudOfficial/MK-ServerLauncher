pipeline {
  agent none
  stages {
    stage('MuView Build') {
      agent {
        docker {
          image 'node:22.16.0'
          args '-p 3000:3000'
        }

      }
      steps {
        dir(path: '/var/jenkins_home/workspace/MK-ServerLauncher_master/view') {
          sh 'echo Building MuView Deps'
          sh 'npm install --registry https://registry.npmmirror.com'
          sh 'echo Building MuView to MuCore'
          sh 'npm run build'
        }

      }
    }

    stage('MuCore Build') {
      agent {
        docker {
          image 'node:22.16.0'
          args '-p 3000:3000'
        }

      }
      steps {
        dir(path: '/var/jenkins_home/workspace/MK-ServerLauncher_master/Core') {
          sh 'echo Building MuCore'
          sh 'sh ./gradlew build -x test'
        }

      }
    }

  }
  environment {
    JAVA_HOME = '/opt/java/openjdk'
  }
}