pipeline {
  agent none
  stages {
    stage('MuView Build') {
      agent {
        docker {
          image 'node:22.16.0-alpine'
        }

      }
      steps {
        dir(path: '/var/jenkins_home/workspace/MK-ServerLauncher_master/view') {
          sh 'echo Building MuView Deps'
          sh 'npm install --registry https://registry.npmmirror.com'
          sh 'echo Building MuView to MuCore'
          sh 'npm run build'
        }

      }
    }

    stage('MuCore Build') {
      agent {
        docker {
          image 'gradle:8.13.0-alpine'
        }

      }
      steps {
        dir(path: '/var/jenkins_home/workspace/MK-ServerLauncher_master/Core') {
          sh 'echo Building MuCore'
          sh 'sh ./gradlew build -x test'
        }

      }
    }

  }
  environment {
    JAVA_HOME = '/opt/java/openjdk'
  }
  post {
    always {
      archiveArtifacts(artifacts: '/var/jenkins_home/workspace/MK-ServerLauncher_master/Core/build/distributions/**', fingerprint: true)
      archiveArtifacts(artifacts: '/var/jenkins_home/workspace/MK-ServerLauncher_master/Core/build/libs/Core-all.jar', fingerprint: true)
    }

  }
}